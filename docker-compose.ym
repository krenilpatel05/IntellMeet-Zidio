version: '3.8'

services:
  backend-api:
    build:
      context: ./server
    ports:
      - "5000:5000"
    environment:
      - PORT=5000
      - NODE_ENV=development
    restart: always

  frontend-ui:
    build:
      context: ./client
    ports:
      - "5173:80"
    depends_on:
      - backend-api
    restart: always